        {
            "title": "Overview",
            "paragraphs": [
                {
                    "type": "plaintext",
                    "elements": [
                        "Stores whether the glowshard has been collected from the room in chapter 1. Sets the glowing shard icon in the room to be visible if collected or not as well."
                    ]
                },
                {
                    "type": "plaintext",
                    "elements": [
                        "Usage in ",
                        {
                            "type": "filename",
                            "value": "gml_GlobalScript_scr_text.gml"
                        },
                        ":"
                    ]
                },
                {
                    "type": "codebox",
                    "elements": [
                        {
                            "type": "code",
                            "value": "global.flag[100] = 1;"
                        }
                    ]
                }
            ]
        },
